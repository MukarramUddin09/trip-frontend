# Local development
VITE_API_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000/ws

# Google OAuth Web Client ID (same as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

